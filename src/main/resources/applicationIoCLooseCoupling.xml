<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="databaseProvider" class="com.loose.coupling.UserDatabaseProvider">
    </bean>
    <bean id="webserviceProvider" class="com.loose.coupling.WebServiceDataProvider">
    </bean>
    <bean id="IoCDatabase" class="com.loose.coupling.UserManager">
        <constructor-arg ref = "databaseProvider"/>
    </bean>
    <bean id="IoCWebservice" class="com.loose.coupling.UserManager">
        <constructor-arg ref = "webserviceProvider"/>
    </bean>

</beans>